{
  "name": "@leharness/cli",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "lh": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --external:openai --external:ulid --external:zod --outfile=dist/index.js && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@leharness/harness": "workspace:*",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "esbuild": "^0.27.2"
  }
}
