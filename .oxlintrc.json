{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "array-callback-return": "error",
    "block-scoped-var": "error",
    "import/no-duplicates": "error",
    "no-caller": "error",
    "no-debugger": "error",
    "no-eval": "error",
    "no-extend-native": "error",
    "no-extra-bind": "error",
    "no-implied-eval": "error",
    "no-iterator": "error",
    "no-multi-str": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-useless-concat": "error",
    "typescript/await-thenable": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/consistent-return": "off",
    "typescript/no-base-to-string": "off",
    "typescript/no-redundant-type-constituents": "off",
    "typescript/no-unnecessary-boolean-literal-compare": "off",
    "typescript/no-unnecessary-type-assertion": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/require-array-sort-compare": "off",
    "eslint/preserve-caught-error": "off",
    "unicorn/no-array-reverse": "off",
    "unicorn/no-array-sort": "off",
    "leharness/no-as-cast": "error",
    "leharness/no-double-exclamation-point": "error",
    "leharness/no-enum": "error",
    "leharness/no-void-return-type": "error"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "**/dist/**",
    ".leharness",
    "coverage",
    "evals/terminal_bench/**",
    "**/*.d.ts"
  ],
  "jsPlugins": ["./scripts/lint-rules/index.mjs"]
}
