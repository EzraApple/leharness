{
  "name": "leharness",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r build",
    "knip": "knip",
    "lint": "biome check .",
    "format": "biome format --write .",
    "package:prepare": "pnpm build && node scripts/prepare-npm-package.mjs",
    "package:pack": "pnpm package:prepare && npm pack dist/npm/leharness --pack-destination dist/npm",
    "package:verify": "pnpm package:pack && node scripts/verify-npm-package.mjs",
    "smoke": "pnpm -r build && node packages/harness/scripts/smoke.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "knip": "^6.11.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
