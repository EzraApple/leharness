{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["evals/**"],
  "workspaces": {
    "apps/cli": {
      "ignoreDependencies": ["openai"]
    },
    "packages/harness": {
      "entry": ["scripts/**/*.mjs"],
      "project": ["src/**/*.ts", "scripts/**/*.mjs"]
    },
    "packages/mcp": {
      "entry": ["scripts/**/*.mjs"],
      "project": ["src/**/*.ts", "scripts/**/*.mjs"]
    }
  }
}
